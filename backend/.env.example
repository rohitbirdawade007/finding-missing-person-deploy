# ─────────────────────────────────────────────────────────────
# Guardian Eye AI v2 — Environment Variables Template
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
# Get from: Atlas → Cluster → Connect → Drivers → Python
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=guardian_eye

# JWT Secret Key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_this_to_a_random_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Admin seed credentials (used by /seed-admin endpoint, remove in production)
ADMIN_EMAIL=admin@guardian.ai
ADMIN_PASSWORD=Admin@1234

# Upload directory (inside backend/)
UPLOAD_DIR=uploads

# CORS origins (comma-separated). Add your Vercel URL after deployment
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Face matching thresholds
# Cosine: lower = more similar (recommended 0.0 - 0.4 range)
COSINE_THRESHOLD=0.4
# Euclidean (FaceNet 512-dim): lower = more similar
EUCLIDEAN_THRESHOLD=10.0

# DeepFace model: "Facenet512" (best accuracy) or "Facenet" (faster)
FACE_MODEL=Facenet512
